# Database Configuration
# For local Docker usage this project maps PostgreSQL to host port 5433.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=openfamily
POSTGRES_USER=openfamily
POSTGRES_PASSWORD=openfamily2024

# Server Configuration
SERVER_PORT=3001
NODE_ENV=development

# Client Configuration
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# Web Push Notifications (Generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com

# JWT Secret (Generate a random string: openssl rand -hex 32)
JWT_SECRET=replace-me-with-a-long-random-secret

# Auth rate limiting (anti brute-force)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Registration (set to false to disable new account creation)
REGISTRATION_ENABLED=true

# Cookie attributes (auth tokens are stored as httpOnly cookies).
# COOKIE_SECURE: true forces Secure flag (HTTPS only). Auto-on in production.
# COOKIE_SAMESITE: lax | strict | none. 'none' requires COOKIE_SECURE=true.
COOKIE_SECURE=
COOKIE_SAMESITE=lax

# JWT token lifetimes (seconds). Defaults: 1h access, 7d refresh.
JWT_ACCESS_TTL_SEC=3600
JWT_REFRESH_TTL_SEC=604800

# Global API rate limit (defaults: 300 req / 60 s / IP).
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=300

# === AI layer (NVIDIA NIM by default) ============================================
# Set AI_ENABLED=false to disable all /api/ai/* routes without removing code.
AI_ENABLED=true

# NVIDIA API key — get one at https://build.nvidia.com (the key starts with "nvapi-").
NVIDIA_API_KEY=

# Override only for on-prem NVIDIA NIM deployments.
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1

# Model tiers. The default 8B model is fast and cheap; the heavy 70B model is
# used for chat and multi-constraint generation; the vision model is used for
# image inputs (e.g. parsing a receipt photo).
AI_MODEL_DEFAULT=meta/llama-3.1-8b-instruct
AI_MODEL_HEAVY=meta/llama-3.3-70b-instruct
AI_MODEL_VISION=meta/llama-3.2-90b-vision-instruct

# Per-user monthly token cap (sum of prompt + completion).
# 0 = unlimited. Recommended: ~2M tokens for a household.
AI_MONTHLY_TOKEN_LIMIT_PER_USER=2000000

# Provider request timeout (ms).
AI_REQUEST_TIMEOUT_MS=30000

# Streaming (SSE) for the future assistant chat endpoint.
AI_STREAMING_ENABLED=true
